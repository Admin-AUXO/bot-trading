    {
      "id": 4,
      "title": "Pack Leaderboard",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "trading-bot-postgres"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "trading-bot-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT day, strategy_pack_id, grade, accepted_count, closed_positions, win_rate_pct, avg_winner_usd, avg_loser_usd, expected_value_usd FROM v_strategy_pack_performance_daily WHERE COALESCE(strategy_pack_id::text, '') ~* '^(${pack:regex})$' AND COALESCE(config_version::text, '') ~* '^(${configVer:regex})$' AND COALESCE(grade::text, '') ~* '^(${grade:regex})$' ORDER BY expected_value_usd DESC, win_rate_pct DESC LIMIT 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "enablePagination": false,
          "reducer": [],
          "show": false
        },
        "showHeader": true
      },
      "description": "Backed by v_strategy_pack_performance_daily for rank-ordered pack performance."
    },
    {
      "id": 5,
      "title": "Pack Grade Trend",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "trading-bot-postgres"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "trading-bot-postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT day::timestamp AS \"time\", strategy_pack_id::text AS metric, grade_score AS value FROM v_strategy_pack_performance_daily WHERE COALESCE(strategy_pack_id::text, '') ~* '^(${pack:regex})$' AND COALESCE(config_version::text, '') ~* '^(${configVer:regex})$' ORDER BY 1, 2",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 4,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "description": "Backed by v_strategy_pack_performance_daily for grade trajectory."
    },
    {
      "id": 6,
      "title": "Config Window Cross-Check",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "trading-bot-postgres"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "trading-bot-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT config_version, window_start_at, window_end_at, candidates_accepted, positions_closed, realized_pnl_usd, win_rate * 100 AS win_rate_pct FROM v_kpi_by_config_window WHERE COALESCE(config_version::text, '') ~* '^(${configVer:regex})$' ORDER BY config_version DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "enablePagination": false,
          "reducer": [],
          "show": false
        },
        "showHeader": true
      },
      "description": "Backed by v_kpi_by_config_window for config-level verification against pack stats."
    }
  ],
  "refresh": "5m",
  "schemaVersion": 41,
  "style": "dark",
  "tags": [
    "bot-trading",
    "analytics",
    "packLeaderboard"
  ],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": {
          "selected": false,
          "text": "All",
          "value": ".*"
        },
        "datasource": {
          "type": "postgres",
          "uid": "trading-bot-postgres"
        },
        "definition": "SELECT id::text AS __value, COALESCE(name, id)::text AS __text FROM \"StrategyPack\" WHERE status <> 'RETIRED' ORDER BY 2",
        "hide": 0,
        "includeAll": true,
        "label": "Pack",
        "multi": true,
        "name": "pack",
        "options": [],
        "query": "SELECT id::text AS __value, COALESCE(name, id)::text AS __text FROM \"StrategyPack\" WHERE status <> 'RETIRED' ORDER BY 2",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": false,
          "text": "All",
          "value": ".*"
        },
        "datasource": {
          "type": "postgres",
          "uid": "trading-bot-postgres"
        },
        "definition": "SELECT DISTINCT config_version::text AS __text, config_version::text AS __value FROM \"ConfigSnapshot\" ORDER BY config_version::int DESC",
        "hide": 0,
        "includeAll": true,
        "label": "Config Version",
        "multi": true,
        "name": "configVer",
        "options": [],
        "query": "SELECT DISTINCT config_version::text AS __text, config_version::text AS __value FROM \"ConfigSnapshot\" ORDER BY config_version::int DESC",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": false,
          "text": "All",
          "value": ".*"
        },
        "datasource": {
          "type": "postgres",
          "uid": "trading-bot-postgres"
        },
        "definition": "SELECT DISTINCT grade AS __text, grade AS __value FROM v_strategy_pack_performance_daily ORDER BY 1",
        "hide": 0,
        "includeAll": true,
        "label": "Grade",
        "multi": true,
        "name": "grade",
        "options": [],
        "query": "SELECT DISTINCT grade AS __text, grade AS __value FROM v_strategy_pack_performance_daily ORDER BY 1",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
