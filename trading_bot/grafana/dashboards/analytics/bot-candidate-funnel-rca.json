          "rawSql": "SELECT COALESCE(SUM(discovered_count), 0) AS value FROM v_candidate_funnel_daily_source WHERE COALESCE(source::text, '') ~* '^(${source:regex})$' AND COALESCE(strategy_pack_id::text, '') ~* '^(${pack:regex})$' AND COALESCE(config_version::text, '') ~* '^(${configVer:regex})$'",
