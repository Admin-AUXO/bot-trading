          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT day::timestamp AS \"time\", stage AS metric, stage_count AS value FROM v_candidate_funnel_daily_source WHERE COALESCE(source::text, '') ~* '^(${source:regex})$' AND COALESCE(strategy_pack_id::text, '') ~* '^(${pack:regex})$' AND COALESCE(config_version::text, '') ~* '^(${configVer:regex})$' ORDER BY 1, 2",
          "refId": "A"
