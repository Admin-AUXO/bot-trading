          "rawSql": "SELECT session_date::timestamp AS \"time\", exit_profile AS metric, realized_pnl_usd AS value FROM v_position_pnl_daily WHERE session_date::timestamp >= $__timeFrom() AND session_date::timestamp <= $__timeTo() AND ('${source}' = '__all' OR source = '${source}') AND ('${exitProfile}' = '__all' OR exit_profile = '${exitProfile}') AND ('${configVersion}' = '__all' OR config_version = CAST('${configVersion}' AS integer)) ORDER BY 1, 2",
