      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "trading-bot-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT created_at, side, lane, position_id, mint, symbol, exit_reason, amount_usd, pnl_usd, tx_signature FROM v_recent_fill_activity WHERE created_at >= $__timeFrom() AND created_at <= $__timeTo() AND COALESCE(exit_reason::text, '') ~* '^(${exitReason:regex})$' ORDER BY created_at DESC LIMIT 200",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
