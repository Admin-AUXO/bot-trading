    {
      "id": 1,
      "title": "Exit Count",
      "type": "stat",
      "datasource": {
        "type": "postgres",
        "uid": "trading-bot-postgres"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "trading-bot-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(position_count), 0) AS value FROM v_position_exit_reason_daily WHERE COALESCE(exit_reason::text, '') ~* '^(${exitReason:regex})$' AND COALESCE(strategy_pack_id::text, '') ~* '^(${pack:regex})$' AND COALESCE(config_version::text, '') ~* '^(${configVer:regex})$'",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
