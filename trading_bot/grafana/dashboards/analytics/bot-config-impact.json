          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT config_version, activated_at, field_path, previous_value, current_value FROM v_config_field_change WHERE ('${configVersion}' = '__all' OR config_version = CAST('${configVersion}' AS integer)) ORDER BY config_version DESC, field_path ASC LIMIT 200",
          "refId": "A"
        }
