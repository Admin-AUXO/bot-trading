    {
      "id": 10,
      "title": "Source / Exit Profile Delta",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "trading-bot-postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "trading-bot-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT p.session_date, p.source, p.exit_profile, p.config_version, p.position_count, p.closed_count, p.realized_pnl_usd, p.avg_return_pct, p.win_rate * 100 AS win_rate_pct FROM v_position_pnl_daily p WHERE session_date::timestamp >= $__timeFrom() AND session_date::timestamp <= $__timeTo() AND ('${source}' = '__all' OR source = '${source}') AND ('${exitProfile}' = '__all' OR exit_profile = '${exitProfile}') AND ('${configVersion}' = '__all' OR config_version = CAST('${configVersion}' AS integer)) ORDER BY p.session_date DESC, p.realized_pnl_usd DESC LIMIT 80",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "enablePagination": false,
          "reducer": [],
          "show": false
        },
        "showHeader": true
      }
    }
