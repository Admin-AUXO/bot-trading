          "rawSql": "SELECT session_date::timestamp AS \"time\", source AS metric, realized_pnl_usd AS value FROM v_source_outcome_daily WHERE session_date::timestamp >= $__timeFrom() AND session_date::timestamp <= $__timeTo() AND COALESCE(source::text, '') ~* '^(${source:regex})$' AND COALESCE(config_version::text, '') ~* '^(${configVersion:regex})$' ORDER BY 1, 2",
