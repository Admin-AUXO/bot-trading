    {
      "id": 8,
      "title": "Endpoint Efficiency",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "trading-bot-postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
