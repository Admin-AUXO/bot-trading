      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "trading-bot-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT provider, endpoint, total_calls, total_units, avg_latency_ms, error_count, error_rate_pct, last_called_at FROM v_api_endpoint_efficiency WHERE COALESCE(provider::text, '') ~* '^(${provider:regex})$' AND COALESCE(endpoint::text, '') ~* '^(${endpoint:regex})$' ORDER BY total_units DESC, total_calls DESC LIMIT 50",
