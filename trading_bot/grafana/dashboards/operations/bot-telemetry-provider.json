      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "trading-bot-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(total_units), 0) AS value FROM v_api_provider_hourly WHERE bucket_at >= $__timeFrom() AND bucket_at <= $__timeTo() AND COALESCE(provider::text, '') ~* '^(${provider:regex})$'",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
