    {
      "id": 7,
      "title": "Open Position Monitor",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "trading-bot-postgres"
      },
      "gridPos": {
        "h": 10,
        "w": 16,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "trading-bot-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT position_id, mint, symbol, source, exit_profile, tp_stage, live_price_usd, stop_distance_pct, return_pct, stale_minutes, intervention_priority, intervention_band, liquidity_usd, volume_5m_usd, buy_sell_ratio FROM v_open_position_monitor WHERE ('${mint}' = '' OR mint = '${mint}') AND ('${symbol}' = '' OR symbol = '${symbol}') AND ('${positionId}' = '' OR position_id = '${positionId}') ORDER BY intervention_priority DESC, stale_minutes DESC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "enablePagination": false,
          "reducer": [],
          "show": false
        },
        "showHeader": true
      }
    },
