          "rawQuery": true,
          "rawSql": "SELECT bucket_at AS \"time\", axis AS metric, fire_rate AS value FROM v_adaptive_threshold_activity WHERE COALESCE(axis::text, '') ~* '^(${axis:regex})$' ORDER BY 1, 2",
          "refId": "A"
        }
