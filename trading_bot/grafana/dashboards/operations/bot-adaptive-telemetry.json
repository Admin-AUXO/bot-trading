  "panels": [
    {
      "id": 1,
      "title": "Mutator Fire Count (24h)",
      "type": "stat",
      "datasource": {
        "type": "postgres",
        "uid": "trading-bot-postgres"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "trading-bot-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(SUM(fire_count), 0) AS value FROM v_adaptive_threshold_activity WHERE bucket_at >= NOW() - INTERVAL '24 hours' AND COALESCE(axis::text, '') ~* '^(${axis:regex})$'",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "description": "Backed by v_adaptive_threshold_activity for recent mutator firing volume."
    },
    {
