          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT mutator_code, SUM(helped_count) AS helped_count, SUM(hurt_count) AS hurt_count, SUM(neutral_count) AS neutral_count FROM v_mutator_outcome_daily WHERE COALESCE(mutator_code::text, '') ~* '^(${mutatorCode:regex})$' GROUP BY mutator_code ORDER BY hurt_count DESC",
