    {
      "id": 6,
      "title": "Run History",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "trading-bot-postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "trading-bot-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT id, status, \"startedAt\" AS started_at, \"completedAt\" AS completed_at, \"totalDiscovered\" AS total_discovered, \"totalStrategyPassed\" AS total_strategy_passed, \"totalMockOpened\" AS total_mock_opened, \"totalMockClosed\" AS total_mock_closed, \"realizedPnlUsd\"::numeric AS realized_pnl_usd, \"winRatePercent\"::numeric AS win_rate_percent, \"averageHoldMinutes\"::numeric AS average_hold_minutes FROM \"ResearchRun\" WHERE \"startedAt\" >= $__timeFrom() AND \"startedAt\" <= $__timeTo() AND ('${runId}' = '' OR id = '${runId}') ORDER BY \"startedAt\" DESC LIMIT 50",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "enablePagination": false,
