    {
      "id": 7,
      "title": "Research Token Funnel",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "trading-bot-postgres"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "trading-bot-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT rt.\"runId\" AS run_id, rt.mint, rt.symbol, rt.source, rt.shortlisted, rt.\"fullEvaluationDone\" AS full_evaluation_done, rt.\"strategyPassed\" AS strategy_passed, rt.\"strategyRejectReason\" AS strategy_reject_reason, rt.\"evaluationDeferReason\" AS evaluation_defer_reason, rt.\"liveTradable\" AS live_tradable, rt.\"researchTradable\" AS research_tradable, rt.\"entryScore\"::numeric AS entry_score, rt.\"exitProfile\" AS exit_profile FROM \"ResearchToken\" rt WHERE ('${runId}' = '' OR rt.\"runId\" = '${runId}') AND ('${source}' = '__all' OR rt.source = '${source}') ORDER BY rt.\"createdAt\" DESC LIMIT 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
