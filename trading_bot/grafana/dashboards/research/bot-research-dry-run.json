    {
      "id": 2,
      "title": "Latest Run PnL",
      "type": "stat",
      "datasource": {
        "type": "postgres",
        "uid": "trading-bot-postgres"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "trading-bot-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(\"realizedPnlUsd\", 0)::numeric AS value FROM \"ResearchRun\" WHERE status = 'COMPLETED' AND \"startedAt\" >= $__timeFrom() AND \"startedAt\" <= $__timeTo() ORDER BY \"startedAt\" DESC LIMIT 1",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
