generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── FACTS: Immutable records of what happened ───

model Trade {
  id             String   @id @default(cuid())
  mode           TradeMode @default(LIVE)
  tradeSource    TradeSource @default(AUTO)
  configProfile  String   @default("default")
  strategy       Strategy
  tokenAddress   String
  tokenSymbol    String   @default("")
  side           TradeSide
  positionId     String?
  walletAddress  String?
  platform       String?
  trancheNumber  Int      @default(1)
  amountSol      Decimal  @db.Decimal(18, 9)
  amountToken    Decimal  @db.Decimal(24, 9)
  priceUsd       Decimal  @db.Decimal(18, 9)
  priceSol       Decimal  @db.Decimal(18, 9)
  slippageBps    Int      @default(0)
  gasFee         Decimal  @default(0) @db.Decimal(18, 9)
  jitoTip        Decimal  @default(0) @db.Decimal(18, 9)
  txSignature    String   @unique
  exitReason     ExitReason?
  pnlSol         Decimal? @db.Decimal(18, 9)
  pnlUsd         Decimal? @db.Decimal(18, 9)
  pnlPercent     Decimal? @db.Decimal(8, 4)
  copyLeadMs     Int?
  regime         MarketRegime @default(NORMAL)
  metadata       Json?
  executedAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  position Position? @relation(fields: [positionId], references: [id])

  @@index([mode, executedAt])
  @@index([mode, configProfile, executedAt])
  @@index([mode, configProfile, side, executedAt])
  @@index([strategy, executedAt])
  @@index([tokenAddress])
  @@index([positionId])
  @@index([executedAt])
  @@index([configProfile])
  @@index([tradeSource, executedAt])
  @@index([createdAt])
}

model Position {
  id               String         @id @default(cuid())
  mode             TradeMode      @default(LIVE)
  tradeSource      TradeSource    @default(AUTO)
  configProfile    String         @default("default")
  strategy         Strategy
  tokenAddress     String
  tokenSymbol      String         @default("")
  platform         String?
  walletSource     String?
  entryPriceSol    Decimal        @db.Decimal(18, 9)
  entryPriceUsd    Decimal        @db.Decimal(18, 9)
  currentPriceSol  Decimal        @db.Decimal(18, 9)
  currentPriceUsd  Decimal        @db.Decimal(18, 9)
  amountSol        Decimal        @db.Decimal(18, 9)
  amountToken      Decimal        @db.Decimal(24, 9)
  remainingToken   Decimal        @db.Decimal(24, 9)
  peakPriceUsd     Decimal        @db.Decimal(18, 9)
  stopLossPercent  Decimal        @db.Decimal(5, 2)
  tranche1Filled   Boolean        @default(true)
  tranche2Filled   Boolean        @default(false)
  exit1Done        Boolean        @default(false)
  exit2Done        Boolean        @default(false)
  exit3Done        Boolean        @default(false)
  status           PositionStatus @default(OPEN)
  exitReason       ExitReason?
  pnlSol           Decimal?       @db.Decimal(18, 9)
  pnlUsd           Decimal?       @db.Decimal(18, 9)
  pnlPercent       Decimal?       @db.Decimal(8, 4)
  entryVolume5m    Decimal?       @db.Decimal(18, 2)
  regime           MarketRegime   @default(NORMAL)
  entryLiquidity   Decimal?       @db.Decimal(18, 2)
  entryMcap        Decimal?       @db.Decimal(18, 2)
  entryHolders     Int?
  entryVolume1h    Decimal?       @db.Decimal(18, 2)
  entryBuyPressure Decimal?       @db.Decimal(5, 2)
  entryRegime      MarketRegime?
  entrySlippageBps Int?
  entryLatencyMs   Int?
  maxPnlPercent    Decimal?       @db.Decimal(8, 4)
  minPnlPercent    Decimal?       @db.Decimal(8, 4)
  priceAfter1h     Decimal?       @db.Decimal(18, 9)
  priceAfter24h    Decimal?       @db.Decimal(18, 9)
  openedAt         DateTime       @default(now())
  closedAt         DateTime?
  updatedAt        DateTime       @updatedAt

  trades Trade[]

  @@index([mode, status])
  @@index([mode, configProfile, status, openedAt])
  @@index([mode, configProfile, status, closedAt])
  @@index([status, priceAfter1h, closedAt])
  @@index([status])
  @@index([strategy, status])
  @@index([openedAt])
  @@index([configProfile])
  @@index([tradeSource, status])
  @@index([status, tokenAddress])
}

model WalletScore {
  id              String   @id @default(cuid())
  walletAddress   String
  winRate         Decimal  @db.Decimal(5, 4)
  maxLossPercent  Decimal  @db.Decimal(5, 4)
  pnlConsistency  Decimal  @db.Decimal(8, 4)
  tradeFrequency  Int
  tokenDiversity  Int
  walletAgeDays   Int
  compositeScore  Decimal  @db.Decimal(6, 4)
  isElite         Boolean  @default(false)
  redFlags        String[]
  archetype       String?
  scoredAt        DateTime @default(now())

  @@index([walletAddress, scoredAt])
  @@index([compositeScore])
  @@index([isElite, scoredAt])
}

model Signal {
  id             String     @id @default(cuid())
  mode           TradeMode  @default(LIVE)
  configProfile  String     @default("default")
  strategy       Strategy
  tokenAddress   String
  tokenSymbol    String     @default("")
  signalType     String
  source         String
  passed         Boolean
  rejectReason   String?
  filterResults  Json?
  metadata       Json?
  regime         MarketRegime?
  solPrice       Decimal?   @db.Decimal(12, 4)
  tokenLiquidity Decimal?   @db.Decimal(18, 2)
  tokenMcap      Decimal?   @db.Decimal(18, 2)
  tokenVolume5m  Decimal?   @db.Decimal(18, 2)
  buyPressure    Decimal?   @db.Decimal(5, 2)
  priceAtSignal  Decimal?   @db.Decimal(18, 9)
  priceAfter5m   Decimal?   @db.Decimal(18, 9)
  priceAfter15m  Decimal?   @db.Decimal(18, 9)
  priceAfter1h   Decimal?   @db.Decimal(18, 9)
  wouldHaveWon   Boolean?
  detectedAt     DateTime   @default(now())
  createdAt      DateTime   @default(now())

  @@index([mode, detectedAt])
  @@index([mode, configProfile, detectedAt])
  @@index([strategy, detectedAt])
  @@index([tokenAddress])
  @@index([passed, detectedAt])
  @@index([wouldHaveWon, detectedAt])
  @@index([detectedAt, priceAfter5m])
  @@index([detectedAt, priceAfter15m])
  @@index([detectedAt, priceAfter1h])
  @@index([tokenAddress, createdAt])
}

model ConfigProfile {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  isActive    Boolean  @default(false)
  mode        TradeMode @default(DRY_RUN)
  settings    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApiCall {
  id          String   @id @default(cuid())
  service     ApiService
  endpoint    String
  strategy    Strategy?
  mode        TradeMode?
  configProfile String?
  purpose     ApiCallPurpose @default(OTHER)
  essential   Boolean  @default(false)
  cacheHit    Boolean  @default(false)
  batchSize   Int?
  credits     Int      @default(1)
  requestedCredits Int?
  statusCode  Int?
  latencyMs   Int?
  success     Boolean  @default(true)
  calledAt    DateTime @default(now())

  @@index([service, calledAt])
  @@index([strategy, calledAt])
  @@index([service, purpose, calledAt])
  @@index([mode, configProfile, calledAt])
}

// ─── METRICS: Computed / aggregated data ───

model DailyStats {
  id              String   @id @default(cuid())
  mode            TradeMode @default(LIVE)
  configProfile   String   @default("default")
  date            DateTime @db.Date
  seriesKey       String
  strategy        Strategy?
  tradesTotal     Int      @default(0)
  tradesWon       Int      @default(0)
  tradesLost      Int      @default(0)
  winRate         Decimal  @default(0) @db.Decimal(5, 4)
  grossPnlSol     Decimal  @default(0) @db.Decimal(18, 9)
  grossPnlUsd     Decimal  @default(0) @db.Decimal(18, 2)
  netPnlUsd       Decimal  @default(0) @db.Decimal(18, 2)
  totalGasFees    Decimal  @default(0) @db.Decimal(18, 9)
  totalJitoTips   Decimal  @default(0) @db.Decimal(18, 9)
  avgWinUsd       Decimal  @default(0) @db.Decimal(18, 2)
  avgLossUsd      Decimal  @default(0) @db.Decimal(18, 2)
  capitalStart    Decimal  @default(0) @db.Decimal(18, 2)
  capitalEnd      Decimal  @default(0) @db.Decimal(18, 2)
  maxDrawdownUsd  Decimal  @default(0) @db.Decimal(18, 2)
  profitFactor    Float    @default(0)
  expectancy      Float    @default(0)
  avgHoldMinutes  Float    @default(0)
  trancheT1Pct    Float    @default(0)
  trancheT2Pct    Float    @default(0)
  trancheT3Pct    Float    @default(0)
  regime          MarketRegime @default(NORMAL)
  createdAt       DateTime @default(now())

  @@unique([date, strategy, mode, configProfile])
  @@unique([date, seriesKey, mode, configProfile])
  @@index([date])
  @@index([mode])
  @@index([mode, configProfile, date])
}

model ApiUsageDaily {
  id                  String     @id @default(cuid())
  date                DateTime   @db.Date
  service             ApiService
  totalCalls          Int        @default(0)
  totalCredits        Int        @default(0)
  budgetTotal         Int        @default(0)
  budgetUsedPercent   Decimal    @default(0) @db.Decimal(5, 2)
  monthlyCreditsUsed  Int        @default(0)
  monthlyCreditsRemaining Int    @default(0)
  dailyBudget         Int        @default(0)
  dailyCreditsRemaining Int      @default(0)
  essentialCalls      Int        @default(0)
  essentialCredits    Int        @default(0)
  nonEssentialCredits Int        @default(0)
  cachedCalls         Int        @default(0)
  avgCreditsPerCall   Decimal    @default(0) @db.Decimal(10, 2)
  peakRps             Decimal    @default(0) @db.Decimal(6, 2)
  avgLatencyMs        Int        @default(0)
  errorCount          Int        @default(0)
  softLimitPct        Decimal    @default(70) @db.Decimal(5, 2)
  hardLimitPct        Decimal    @default(100) @db.Decimal(5, 2)
  quotaStatus         QuotaStatus @default(HEALTHY)
  quotaSource         QuotaSource @default(INTERNAL)
  providerCycleStart  DateTime?
  providerCycleEnd    DateTime?
  providerReportedUsed Int?
  providerReportedRemaining Int?
  providerReportedOverage Int?
  providerReportedOverageCost Decimal? @db.Decimal(18, 4)
  pauseTriggeredAt    DateTime?
  pauseReason         String?
  createdAt           DateTime   @default(now())

  @@unique([date, service])
  @@index([date])
}

model ApiEndpointDaily {
  id                String         @id @default(cuid())
  date              DateTime       @db.Date
  service           ApiService
  endpoint          String
  dimensionKey      String
  strategy          Strategy?
  mode              TradeMode?
  configProfile     String?
  purpose           ApiCallPurpose @default(OTHER)
  essential         Boolean        @default(false)
  totalCalls        Int            @default(0)
  totalCredits      Int            @default(0)
  cachedCalls       Int            @default(0)
  avgCreditsPerCall Decimal        @default(0) @db.Decimal(10, 2)
  avgLatencyMs      Int            @default(0)
  errorCount        Int            @default(0)
  avgBatchSize      Decimal        @default(0) @db.Decimal(10, 2)
  createdAt         DateTime       @default(now())

  @@unique([date, service, dimensionKey])
  @@index([date, service])
  @@index([service, endpoint, date])
  @@index([mode, configProfile, date])
}

model RegimeSnapshot {
  id         String       @id @default(cuid())
  regime     MarketRegime
  solPrice   Decimal      @db.Decimal(12, 4)
  solChange5m  Decimal    @default(0) @db.Decimal(6, 4)
  solChange1h  Decimal    @default(0) @db.Decimal(6, 4)
  trendingCount Int       @default(0)
  rollingWinRate Decimal  @default(0) @db.Decimal(5, 4)
  snappedAt  DateTime     @default(now())

  @@index([snappedAt])
}

model BotState {
  id             String       @id @default("singleton")
  capitalUsd     Decimal      @db.Decimal(18, 2)
  capitalSol     Decimal      @db.Decimal(18, 9)
  walletBalance  Decimal      @db.Decimal(18, 9)
  dailyLossUsd   Decimal      @default(0) @db.Decimal(18, 2)
  weeklyLossUsd  Decimal      @default(0) @db.Decimal(18, 2)
  dailyLossLimit Decimal      @db.Decimal(18, 2)
  weeklyLossLimit Decimal     @db.Decimal(18, 2)
  capitalLevel   CapitalLevel @default(NORMAL)
  regime         MarketRegime @default(NORMAL)
  rollingWinRate Decimal      @default(0.5) @db.Decimal(5, 4)
  totalTradesCount Int        @default(0)
  isRunning      Boolean      @default(false)
  pauseReason    String?
  pauseReasons   String[]     @default([])
  lastDailyReset DateTime     @default(now())
  lastWeeklyReset DateTime    @default(now())
  updatedAt      DateTime     @updatedAt
}

model TokenSnapshot {
  id              String   @id @default(cuid())
  tokenAddress    String
  tokenSymbol     String   @default("")
  trigger         String
  priceUsd        Decimal  @db.Decimal(18, 9)
  priceSol        Decimal? @db.Decimal(18, 9)
  priceChange5m   Decimal? @db.Decimal(8, 4)
  priceChange1h   Decimal? @db.Decimal(8, 4)
  priceChange24h  Decimal? @db.Decimal(8, 4)
  volume5m        Decimal? @db.Decimal(18, 2)
  volume1h        Decimal? @db.Decimal(18, 2)
  volume24h       Decimal? @db.Decimal(18, 2)
  buyVolume5m     Decimal? @db.Decimal(18, 2)
  sellVolume5m    Decimal? @db.Decimal(18, 2)
  liquidity       Decimal? @db.Decimal(18, 2)
  marketCap       Decimal? @db.Decimal(18, 2)
  fdv             Decimal? @db.Decimal(18, 2)
  holders         Int?
  uniqueWallets5m Int?
  buyPressure     Decimal? @db.Decimal(5, 2)
  top10HolderPct  Decimal? @db.Decimal(5, 2)
  freezeable      Boolean?
  mintAuthority   Boolean?
  signalId        String?
  positionId      String?
  tradeId         String?
  capturedAt      DateTime @default(now())

  @@index([tokenAddress, capturedAt])
  @@index([trigger, capturedAt])
  @@index([positionId])
  @@index([signalId])
}

// ─── PHASE 2: Analytics Foundation ───

model WalletActivity {
  id              String   @id @default(cuid())
  walletAddress   String
  tokenAddress    String
  tokenSymbol     String   @default("")
  side            TradeSide
  amountSol       Decimal  @db.Decimal(18, 9)
  amountToken     Decimal? @db.Decimal(24, 9)
  priceAtTrade    Decimal? @db.Decimal(18, 9)
  priceAfter1m    Decimal? @db.Decimal(18, 9)
  priceAfter5m    Decimal? @db.Decimal(18, 9)
  priceAfter15m   Decimal? @db.Decimal(18, 9)
  priceAfter1h    Decimal? @db.Decimal(18, 9)
  peakPriceAfter  Decimal? @db.Decimal(18, 9)
  txSignature     String   @unique
  walletArchetype String?
  isElite         Boolean  @default(false)
  detectedAt      DateTime @default(now())

  @@index([walletAddress, detectedAt])
  @@index([tokenAddress, detectedAt])
  @@index([isElite, detectedAt])
  @@index([side, detectedAt])
  @@index([detectedAt, priceAfter1m])
  @@index([detectedAt, priceAfter5m])
  @@index([detectedAt, priceAfter15m])
  @@index([detectedAt, priceAfter1h])
}

model GraduationEvent {
  id              String   @id @default(cuid())
  tokenAddress    String
  tokenSymbol     String   @default("")
  platform        String
  creator         String   @default("")
  liquidity       Decimal? @db.Decimal(18, 2)
  marketCap       Decimal? @db.Decimal(18, 2)
  holders         Int?
  priceAtGrad     Decimal? @db.Decimal(18, 9)
  priceAfter1m    Decimal? @db.Decimal(18, 9)
  priceAfter5m    Decimal? @db.Decimal(18, 9)
  priceAfter15m   Decimal? @db.Decimal(18, 9)
  priceAfter1h    Decimal? @db.Decimal(18, 9)
  peakPriceAfter  Decimal? @db.Decimal(18, 9)
  rugDetected     Boolean  @default(false)
  rugTimeMinutes  Int?
  wasTraded       Boolean  @default(false)
  positionId      String?
  graduatedAt     DateTime @default(now())

  @@index([tokenAddress])
  @@index([platform, graduatedAt])
  @@index([wasTraded, graduatedAt])
  @@index([rugDetected, graduatedAt])
  @@index([graduatedAt, priceAfter1m])
  @@index([graduatedAt, priceAfter5m])
  @@index([graduatedAt, priceAfter15m])
  @@index([graduatedAt, priceAfter1h])
}

model MarketTick {
  id              String       @id @default(cuid())
  solPriceUsd     Decimal      @db.Decimal(12, 4)
  solChange5m     Decimal      @default(0) @db.Decimal(6, 4)
  solChange1h     Decimal      @default(0) @db.Decimal(6, 4)
  solChange24h    Decimal      @default(0) @db.Decimal(6, 4)
  trendingCount   Int          @default(0)
  totalVolume5m   Decimal?     @db.Decimal(18, 2)
  newTokens1h     Int?
  regime          MarketRegime @default(NORMAL)
  breadth         Decimal?     @db.Decimal(5, 2)
  tickedAt        DateTime     @default(now())

  @@index([tickedAt])
  @@index([regime, tickedAt])
}

// ─── ENUMS ───

enum Strategy {
  S1_COPY
  S2_GRADUATION
  S3_MOMENTUM
}

enum TradeSide {
  BUY
  SELL
}

enum PositionStatus {
  OPEN
  PARTIALLY_CLOSED
  CLOSED
}

enum ExitReason {
  STOP_LOSS
  TIME_STOP
  TAKE_PROFIT_T1
  TAKE_PROFIT_T2
  TAKE_PROFIT_T3
  TRAILING_STOP
  FADE_EXIT
  MIRROR_SELL
  TIME_LIMIT
  MANUAL
  REGIME_EXIT
  DAILY_LIMIT
}

enum MarketRegime {
  HOT
  NORMAL
  CHOPPY
  RISK_OFF
}

enum CapitalLevel {
  NORMAL
  CAUTION
  WARNING
  CRITICAL
  HALT
}

enum ApiService {
  HELIUS
  BIRDEYE
  JUPITER
  JITO
}

enum ApiCallPurpose {
  ENTRY_SCAN
  EXIT_MONITOR
  WALLET_SCORING
  WALLET_DISCOVERY
  ANALYTICS
  RECONCILIATION
  EXECUTION
  REGIME
  MARKET_TICK
  BACKFILL
  OTHER
}

enum QuotaStatus {
  HEALTHY
  SOFT_LIMIT
  HARD_LIMIT
  PAUSED
}

enum QuotaSource {
  INTERNAL
  PROVIDER
  MIXED
}

enum TradeMode {
  LIVE
  DRY_RUN
}

enum TradeSource {
  AUTO
  MANUAL
}
