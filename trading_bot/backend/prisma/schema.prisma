generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}





enum CandidateStatus {
  DISCOVERED
  REJECTED
  SKIPPED
  ACCEPTED
  BOUGHT
  EXITED
  ERROR
}

enum PositionStatus {
  OPEN
  CLOSED
}

enum FillSide {
  BUY
  SELL
}

enum DiscoveryLabRunStatus {
  RUNNING
  COMPLETED
  FAILED
  INTERRUPTED
}

enum DiscoveryLabPackKind {
  CREATED
  WORKSPACE
  CUSTOM
}

enum ProviderName {
  BIRDEYE
  HELIUS
}








model TokenMetrics {
  id           String @id @default(cuid())
  mint         String
  candidateId  String?
  positionId   String?
  trigger      String


  priceUsd     Decimal? @db.Decimal(18, 9)
  liquidityUsd Decimal? @db.Decimal(18, 2)
  marketCapUsd Decimal? @db.Decimal(18, 2)
  fdvUsd       Decimal? @db.Decimal(18, 2)


  holders      Int?
  top10HolderPct    Decimal? @db.Decimal(8, 4)
  largestHolderPct  Decimal? @db.Decimal(8, 4)


  volume1mUsd  Decimal? @db.Decimal(18, 2)
  buys1m       Int?
  sells1m      Int?
  trades1m     Int?
  uniqueWallets1m Int?


  priceChange1mPct Decimal? @db.Decimal(12, 4)


  decimals     Int?
  totalSupply  Decimal? @db.Decimal(30, 0)


  mintAuthorityActive           Boolean?
  freezeAuthorityActive         Boolean?
  transferFeeEnabled           Boolean?
  trueToken                    Boolean?
  token2022                    Boolean?
  nonTransferable               Boolean?
  fakeToken                     Boolean?
  honeypot                      Boolean?
  freezeable                    Boolean?


  compositeScore Decimal? @db.Decimal(8, 6)
  riskScore     Decimal? @db.Decimal(8, 6)


  metadata      Json?
  capturedAt    DateTime @default(now())


  latestCandidate        Candidate?   @relation("CandidateLatestMetrics")
  candidateSnapshots     Candidate[]  @relation("CandidateSnapshots")


  positionSnapshots      Position[]  @relation("PositionSnapshots")

  @@index([mint, capturedAt])
  @@index([candidateId])
  @@index([positionId])
  @@index([trigger, capturedAt])
}





model Candidate {
  id               String           @id @default(cuid())
  mint             String
  symbol           String           @default("")
  name             String           @default("")
  source           String           @default("")
  strategyPresetId String           @default("FIRST_MINUTE_POSTGRAD_CONTINUATION")


  status           CandidateStatus  @default(DISCOVERED)
  rejectReason     String?
  entryOrigin     String?


  discoveryRecipeName String?
  creator          String?
  platformId       String?


  discoveredAt     DateTime         @default(now())
  graduatedAt      DateTime?
  creationAt       DateTime?
  recentListingAt  DateTime?
  lastTradeAt      DateTime?


  scheduledEvaluationAt DateTime
  lastEvaluatedAt      DateTime?
  acceptedAt            DateTime?
  boughtAt              DateTime?


  discoveryLabRunId  String?
  liveStrategyRunId  String?
  liveStrategyPackId String?
  discoveryLabRun    DiscoveryLabRun? @relation(fields: [discoveryLabRunId], references: [id], onDelete: SetNull)


  latestMetricsId   String?  @unique
  latestMetrics     TokenMetrics? @relation("CandidateLatestMetrics", fields: [latestMetricsId], references: [id])


  metadata          Json?


  positionId        String?
  position          Position? @relation(fields: [positionId], references: [id])


  snapshots         TokenMetrics[] @relation("CandidateSnapshots")







  @@index([status, scheduledEvaluationAt])
  @@index([mint, status])
  @@index([strategyPresetId, status, scheduledEvaluationAt])
  @@index([discoveryLabRunId, discoveredAt])
  @@index([discoveredAt])
  @@index([creator])
  @@index([platformId])
  @@index([mint, strategyPresetId, status])
  @@index([positionId])
}




model Position {
  id               String         @id @default(cuid())
  mint             String
  symbol           String         @default("")
  strategy         String         @default("S2_GRADUATION")
  strategyPresetId String         @default("FIRST_MINUTE_POSTGRAD_CONTINUATION")
  status           PositionStatus @default(OPEN)
  entryOrigin      String?


  entryPriceUsd    Decimal       @db.Decimal(18, 9)
  entryLiquidityUsd Decimal?     @db.Decimal(18, 2)
  entryMktCapUsd   Decimal?       @db.Decimal(18, 2)
  entryHolders     Int?
  entryVolume5mUsd Decimal?      @db.Decimal(18, 2)
  entryBuySellRatio Decimal?     @db.Decimal(12, 4)
  entryTop10HolderPct Decimal?    @db.Decimal(8, 4)


  currentPriceUsd  Decimal       @db.Decimal(18, 9)
  peakPriceUsd     Decimal       @db.Decimal(18, 9)
  stopLossPriceUsd Decimal      @db.Decimal(18, 9)
  takeProfit1PriceUsd Decimal   @db.Decimal(18, 9)
  takeProfit2PriceUsd Decimal   @db.Decimal(18, 9)
  trailingStopPercent Decimal   @db.Decimal(6, 2)


  amountUsd       Decimal       @db.Decimal(18, 9)
  amountToken      Decimal       @db.Decimal(24, 9)
  remainingToken   Decimal       @db.Decimal(24, 9)


  tp1Done          Boolean       @default(false)
  tp2Done          Boolean       @default(false)
  exitReason       String?
  exitProfile      String?


  maxAdverseExcursionPct Decimal? @db.Decimal(8, 4)
  timeToFirstProfitMins  Int?


  discoveryLabRunId String?
  liveStrategyRunId String?
  discoveryLabRun   DiscoveryLabRun? @relation(fields: [discoveryLabRunId], references: [id], onDelete: SetNull)


  reportAgeMsAtEntry Int?
  openedAt          DateTime      @default(now())
  closedAt          DateTime?
  metadata          Json?


  fills             Fill[]
  candidates        Candidate[]
  snapshots         TokenMetrics[] @relation("PositionSnapshots")

  @@index([status, openedAt])
  @@index([mint, status])
  @@index([strategyPresetId, status, openedAt])
  @@index([discoveryLabRunId, openedAt])
}





model Fill {
  id           String   @id @default(cuid())
  positionId   String
  position      Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  side         FillSide


  priceUsd     Decimal  @db.Decimal(18, 9)
  amountUsd    Decimal  @db.Decimal(18, 9)
  amountToken  Decimal  @db.Decimal(24, 9)
  pnlUsd       Decimal? @db.Decimal(18, 9)
  txSignature  String?


  executionReason  String?
  executionMode    String?
  entryOrigin      String?


  totalLatencyMs           Int?
  quoteLatencyMs           Int?
  swapBuildLatencyMs       Int?
  senderBuildLatencyMs     Int?
  broadcastConfirmLatencyMs Int?
  settlementReadLatencyMs  Int?


  executionSlippageBps     Decimal? @db.Decimal(10, 4)
  quotedOutAmountUsd       Decimal? @db.Decimal(18, 9)
  actualOutAmountUsd       Decimal? @db.Decimal(18, 9)
  quotedOutAmountToken     Decimal? @db.Decimal(24, 9)
  actualOutAmountToken    Decimal? @db.Decimal(24, 9)

  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([positionId, createdAt])
  @@index([side, createdAt])
  @@index([executionReason, createdAt])
  @@index([txSignature])
}





model DiscoveryLabPack {
  id             String               @id
  kind           DiscoveryLabPackKind
  name           String
  description    String               @default("")
  thesis         String?
  targetPnlBand  Json?
  defaultProfile String
  defaultSources Json
  thresholdOverrides Json?
  recipes        Json
  sourcePath     String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([kind, updatedAt])
  @@index([updatedAt])
}

model DiscoveryLabRun {
  id                   String                 @id
  status               DiscoveryLabRunStatus  @default(RUNNING)
  packId               String
  packName             String
  packKind             DiscoveryLabPackKind
  profile              String
  sources              Json
  allowOverfiltered     Boolean                @default(false)


  queryCount          Int?
  winnerCount         Int?
  evaluationCount     Int?
  thresholdOverrides  Json?


  packSnapshot        Json
  report              Json?
  strategyCalibration Json?
  marketRegime        Json?
  marketRegimeObservedAt DateTime?
  statsSnapshot       Json?
  configSnapshot      Json?


  appliedToLiveAt        DateTime?
  appliedConfigVersionId Int?


  stdout        String?
  stderr        String?
  errorMessage  String?


  createdAt     DateTime @default(now())
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  updatedAt     DateTime @updatedAt


  candidates    Candidate[]
  positions     Position[]
  queries       DiscoveryLabRunQuery[]
  tokens        DiscoveryLabRunToken[]

  @@index([status, startedAt])
  @@index([packId, startedAt])
  @@index([completedAt])
}

model DiscoveryLabRunQuery {
  id                   String          @id @default(cuid())
  runId                String
  run                  DiscoveryLabRun @relation(fields: [runId], references: [id], onDelete: Cascade)


  key                  String
  source               String
  recipeName           String
  recipeMode           String


  filterCount    Int
  returnedCount  Int
  selectedCount  Int
  goodCount      Int
  rejectCount    Int


  selectionRatePercent  Decimal? @db.Decimal(8, 4)
  passRatePercent      Decimal? @db.Decimal(8, 4)
  winnerHitRatePercent Decimal? @db.Decimal(8, 4)


  avgGoodPlayScore      Decimal? @db.Decimal(8, 6)
  avgGoodEntryScore     Decimal? @db.Decimal(8, 6)
  avgSelectedPlayScore   Decimal? @db.Decimal(8, 6)
  avgSelectedEntryScore Decimal? @db.Decimal(8, 6)

  estimatedCu  Int?
  metadata     Json?
  createdAt   DateTime @default(now())

  @@unique([runId, key])
  @@index([runId, source])
  @@index([runId, recipeName])
}

model DiscoveryLabRunToken {
  id              String          @id @default(cuid())
  runId           String
  run             DiscoveryLabRun @relation(fields: [runId], references: [id], onDelete: Cascade)


  mint            String
  symbol          String          @default("")
  source          String          @default("")
  recipeName      String
  recipeMode      String


  passed          Boolean         @default(false)
  grade           String?
  rejectReason    String?


  playScore       Decimal?        @db.Decimal(8, 6)
  entryScore      Decimal?        @db.Decimal(8, 6)


  priceUsd        Decimal?        @db.Decimal(18, 9)
  liquidityUsd    Decimal?        @db.Decimal(18, 2)
  marketCapUsd    Decimal?        @db.Decimal(18, 2)
  holders         Int?
  top10HolderPct  Decimal?        @db.Decimal(8, 4)
  largestHolderPct Decimal?       @db.Decimal(8, 4)
  buySellRatio    Decimal?        @db.Decimal(12, 4)
  priceChange5mPct Decimal?       @db.Decimal(12, 4)
  volume5mUsd     Decimal?        @db.Decimal(18, 2)


  timeSinceGraduationMin Decimal? @db.Decimal(12, 4)
  timeSinceCreationMin   Decimal? @db.Decimal(12, 4)


  softIssues      Json?
  notes           Json?


  isWinner        Boolean         @default(false)
  winnerScore     Decimal?        @db.Decimal(8, 6)
  winnerRecipeNames Json?


  linkedCandidateId  String?
  linkedPositionId  String?
  tradeSetup         Json?

  createdAt       DateTime        @default(now())

  @@index([runId, mint])
  @@index([runId, recipeName])
  @@index([runId, passed, playScore])
}





model BotState {
  id                String    @id @default("singleton")
  tradeMode         String    @default("DRY_RUN")
  capitalUsd        Decimal   @db.Decimal(18, 9)
  cashUsd           Decimal   @db.Decimal(18, 9)
  realizedPnlUsd    Decimal   @default(0) @db.Decimal(18, 9)
  lastDiscoveryAt   DateTime?
  lastEvaluationAt  DateTime?
  lastExitCheckAt   DateTime?
  pauseReason       String?
  updatedAt         DateTime  @updatedAt

  @@unique([id])
}

model RuntimeConfig {
  id        String   @id @default("singleton")
  settings  Json
  updatedAt DateTime @updatedAt
}

model RuntimeConfigVersion {
  id                 Int      @id @default(autoincrement())
  settings           Json
  changedPaths       Json?
  liveAffectingPaths Json?
  appliedBy          String   @default("system")
  activatedAt        DateTime @default(now())

  @@index([activatedAt])
  @@index([appliedBy, activatedAt])
}





model OperatorEvent {
  id          String   @id @default(cuid())
  kind        String
  level       String   @default("info")
  title       String
  detail      String?
  entityType  String?
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([kind, createdAt])
  @@index([entityType, entityId, createdAt])
}

model ExitEvent {
  id          String   @id @default(cuid())
  positionId  String
  reason      String
  profile     String?
  priceUsd   Decimal  @db.Decimal(18, 9)
  pnlUsd     Decimal? @db.Decimal(18, 9)
  createdAt  DateTime @default(now())

  @@index([positionId])
  @@index([createdAt])
}

model ApiEvent {
  id         String       @id @default(cuid())
  provider   ProviderName
  endpoint   String
  units      Int
  success    Boolean      @default(true)
  latencyMs  Int?
  metadata   Json?
  calledAt   DateTime     @default(now())

  @@index([provider, calledAt])
  @@index([endpoint, calledAt])
}

model RawApiPayload {
  id             String       @id @default(cuid())
  provider       ProviderName
  endpoint       String
  requestMethod  String       @default("GET")
  entityKey      String?
  success        Boolean      @default(true)
  statusCode     Int?
  latencyMs      Int?
  requestParams  Json?
  responseBody   Json?
  errorMessage   String?
  capturedAt     DateTime     @default(now())

  @@index([provider, endpoint, capturedAt])
  @@index([entityKey, capturedAt])
}





model SharedTokenFact {
  mint String @id


  symbol            String    @default("")
  name              String    @default("")
  source            String?


  latestDiscovery   Json?
  latestDetail      Json?
  latestOverview    Json?
  latestMetadata    Json?
  latestMarketStats Json?
  latestTradeData   Json?
  latestMintAuthorities Json?
  latestHolderConcentration Json?
  latestSecurity    Json?


  latestDiscoveryAt          DateTime?
  latestDetailAt              DateTime?
  latestOverviewAt            DateTime?
  latestMetadataAt            DateTime?
  latestMarketStatsAt          DateTime?
  latestTradeDataAt            DateTime?
  latestMintAuthoritiesAt      DateTime?
  latestHolderConcentrationAt  DateTime?
  latestSecurityAt            DateTime?


  firstSeenAt       DateTime  @default(now())
  lastSeenAt        DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([lastSeenAt])
  @@index([source, lastSeenAt])
  @@index([mint])
}

model SharedTokenFactMigrationSignal {
  id          String   @id @default(cuid())
  programId   String
  signature   String   @unique
  observedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([programId, observedAt])
}
