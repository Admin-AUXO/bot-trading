generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CandidateStatus {
  DISCOVERED
  REJECTED
  SKIPPED
  ACCEPTED
  BOUGHT
  EXITED
  ERROR
}

enum PositionStatus {
  OPEN
  CLOSED
}

enum FillSide {
  BUY
  SELL
}

enum ProviderName {
  BIRDEYE
  HELIUS
}

model Candidate {
  id                   String          @id @default(cuid())
  mint                 String          @unique
  symbol               String          @default("")
  name                 String          @default("")
  source               String          @default("")
  creator              String?
  platformId           String?
  status               CandidateStatus @default(DISCOVERED)
  rejectReason         String?
  discoveredAt         DateTime        @default(now())
  graduatedAt          DateTime?
  creationAt           DateTime?
  recentListingAt      DateTime?
  lastTradeAt          DateTime?
  decimals             Int?
  progressPercent      Decimal?        @db.Decimal(12, 4)
  priceUsd             Decimal?        @db.Decimal(18, 9)
  liquidityUsd         Decimal?        @db.Decimal(18, 2)
  marketCapUsd         Decimal?        @db.Decimal(18, 2)
  fdvUsd               Decimal?        @db.Decimal(18, 2)
  totalSupply          Decimal?        @db.Decimal(30, 0)
  circulatingSupply    Decimal?        @db.Decimal(30, 0)
  holders              Int?
  volume1mUsd          Decimal?        @db.Decimal(18, 2)
  volume5mUsd          Decimal?        @db.Decimal(18, 2)
  volume30mUsd         Decimal?        @db.Decimal(18, 2)
  volume1hUsd          Decimal?        @db.Decimal(18, 2)
  volume24hUsd         Decimal?        @db.Decimal(18, 2)
  volume1mChangePercent Decimal?       @db.Decimal(12, 4)
  volume5mChangePercent Decimal?       @db.Decimal(12, 4)
  volume30mChangePercent Decimal?      @db.Decimal(12, 4)
  volume1hChangePercent Decimal?       @db.Decimal(12, 4)
  volume24hChangePercent Decimal?      @db.Decimal(12, 4)
  volumeBuy1mUsd       Decimal?        @db.Decimal(18, 2)
  volumeBuy5mUsd       Decimal?        @db.Decimal(18, 2)
  volumeBuy30mUsd      Decimal?        @db.Decimal(18, 2)
  volumeBuy1hUsd       Decimal?        @db.Decimal(18, 2)
  volumeBuy24hUsd      Decimal?        @db.Decimal(18, 2)
  volumeSell1mUsd      Decimal?        @db.Decimal(18, 2)
  volumeSell5mUsd      Decimal?        @db.Decimal(18, 2)
  volumeSell30mUsd     Decimal?        @db.Decimal(18, 2)
  volumeSell1hUsd      Decimal?        @db.Decimal(18, 2)
  volumeSell24hUsd     Decimal?        @db.Decimal(18, 2)
  uniqueWallets1m      Int?
  uniqueWallets5m      Int?
  uniqueWallets30m     Int?
  uniqueWallets1h      Int?
  uniqueWallets24h     Int?
  trades1m             Int?
  trades5m             Int?
  trades30m            Int?
  trades1h             Int?
  trades24h            Int?
  buys1m               Int?
  buys5m               Int?
  buys30m              Int?
  buys1h               Int?
  buys24h              Int?
  sells1m              Int?
  sells5m              Int?
  sells30m             Int?
  sells1h              Int?
  sells24h             Int?
  buySellRatio         Decimal?        @db.Decimal(12, 4)
  priceChange1mPercent Decimal?        @db.Decimal(12, 4)
  priceChange5mPercent Decimal?        @db.Decimal(12, 4)
  priceChange30mPercent Decimal?       @db.Decimal(12, 4)
  priceChange1hPercent Decimal?        @db.Decimal(12, 4)
  priceChange24hPercent Decimal?       @db.Decimal(12, 4)
  graduationAgeSeconds Int?
  top10HolderPercent   Decimal?        @db.Decimal(8, 4)
  largestHolderPercent Decimal?        @db.Decimal(8, 4)
  largestAccountsCount Int?
  largestHolderAddress String?
  creatorBalancePercent Decimal?       @db.Decimal(8, 4)
  ownerBalancePercent   Decimal?       @db.Decimal(8, 4)
  updateAuthorityBalancePercent Decimal? @db.Decimal(8, 4)
  top10UserPercent    Decimal?         @db.Decimal(8, 4)
  mintAuthorityActive  Boolean?
  freezeAuthorityActive Boolean?
  transferFeeEnabled   Boolean?
  transferFeePercent   Decimal?        @db.Decimal(8, 4)
  trueToken            Boolean?
  token2022            Boolean?
  nonTransferable      Boolean?
  fakeToken            Boolean?
  honeypot             Boolean?
  freezeable           Boolean?
  mutableMetadata      Boolean?
  lastFilterSnapshotAt DateTime?
  securityCheckedAt    DateTime?
  scheduledEvaluationAt DateTime
  lastEvaluatedAt      DateTime?
  acceptedAt           DateTime?
  boughtAt             DateTime?
  metadata             Json?
  metrics              Json?
  positionId           String?
  position             Position?       @relation(fields: [positionId], references: [id])
  snapshots            TokenSnapshot[]

  @@index([status, scheduledEvaluationAt])
  @@index([status, liquidityUsd])
  @@index([status, volume5mUsd])
  @@index([status, buySellRatio])
  @@index([status, top10HolderPercent])
  @@index([status, largestHolderPercent])
  @@index([discoveredAt])
}

model Position {
  id                 String         @id @default(cuid())
  mint               String
  symbol             String         @default("")
  strategy           String         @default("S2_GRADUATION")
  status             PositionStatus @default(OPEN)
  entryPriceUsd      Decimal        @db.Decimal(18, 9)
  currentPriceUsd    Decimal        @db.Decimal(18, 9)
  peakPriceUsd       Decimal        @db.Decimal(18, 9)
  stopLossPriceUsd   Decimal        @db.Decimal(18, 9)
  takeProfit1PriceUsd Decimal       @db.Decimal(18, 9)
  takeProfit2PriceUsd Decimal       @db.Decimal(18, 9)
  trailingStopPercent Decimal       @db.Decimal(6, 2)
  amountUsd          Decimal        @db.Decimal(18, 9)
  amountToken        Decimal        @db.Decimal(24, 9)
  remainingToken     Decimal        @db.Decimal(24, 9)
  tp1Done            Boolean        @default(false)
  tp2Done            Boolean        @default(false)
  exitReason         String?
  openedAt           DateTime       @default(now())
  closedAt           DateTime?
  metadata           Json?
  fills              Fill[]
  candidates         Candidate[]
  snapshots          TokenSnapshot[]

  @@index([status, openedAt])
  @@index([mint, status])
}

model Fill {
  id          String   @id @default(cuid())
  positionId  String
  position    Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  side        FillSide
  priceUsd    Decimal  @db.Decimal(18, 9)
  amountUsd   Decimal  @db.Decimal(18, 9)
  amountToken Decimal  @db.Decimal(24, 9)
  pnlUsd      Decimal? @db.Decimal(18, 9)
  txSignature String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([positionId, createdAt])
}

model BotState {
  id              String   @id @default("singleton")
  tradeMode       String   @default("DRY_RUN")
  capitalUsd      Decimal  @db.Decimal(18, 9)
  cashUsd         Decimal  @db.Decimal(18, 9)
  realizedPnlUsd  Decimal  @default(0) @db.Decimal(18, 9)
  lastDiscoveryAt DateTime?
  lastEvaluationAt DateTime?
  lastExitCheckAt DateTime?
  pauseReason     String?
  updatedAt       DateTime @updatedAt
}

model RuntimeConfig {
  id        String   @id @default("singleton")
  settings  Json
  updatedAt DateTime @updatedAt
}

model ApiEvent {
  id         String       @id @default(cuid())
  provider   ProviderName
  endpoint   String
  units      Int
  success    Boolean      @default(true)
  latencyMs  Int?
  metadata   Json?
  calledAt   DateTime     @default(now())

  @@index([provider, calledAt])
  @@index([endpoint, calledAt])
}

model RawApiPayload {
  id            String       @id @default(cuid())
  provider      ProviderName
  endpoint      String
  requestMethod String       @default("GET")
  entityKey     String?
  success       Boolean      @default(true)
  statusCode    Int?
  latencyMs     Int?
  requestParams Json?
  responseBody  Json?
  errorMessage  String?
  capturedAt    DateTime     @default(now())

  @@index([provider, endpoint, capturedAt])
  @@index([entityKey, capturedAt])
}

model TokenSnapshot {
  id                  String   @id @default(cuid())
  candidateId         String?
  candidate           Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  positionId          String?
  position            Position? @relation(fields: [positionId], references: [id], onDelete: SetNull)
  mint                String
  symbol              String   @default("")
  trigger             String
  source              String?
  creator             String?
  platformId          String?
  creationAt          DateTime?
  recentListingAt     DateTime?
  lastTradeAt         DateTime?
  decimals            Int?
  progressPercent     Decimal? @db.Decimal(12, 4)
  priceUsd            Decimal? @db.Decimal(18, 9)
  liquidityUsd        Decimal? @db.Decimal(18, 2)
  marketCapUsd        Decimal? @db.Decimal(18, 2)
  fdvUsd              Decimal? @db.Decimal(18, 2)
  totalSupply         Decimal? @db.Decimal(30, 0)
  circulatingSupply   Decimal? @db.Decimal(30, 0)
  holders             Int?
  volume1mUsd         Decimal? @db.Decimal(18, 2)
  volume5mUsd         Decimal? @db.Decimal(18, 2)
  volume30mUsd        Decimal? @db.Decimal(18, 2)
  volume1hUsd         Decimal? @db.Decimal(18, 2)
  volume24hUsd        Decimal? @db.Decimal(18, 2)
  volume1mChangePercent Decimal? @db.Decimal(12, 4)
  volume5mChangePercent Decimal? @db.Decimal(12, 4)
  volume30mChangePercent Decimal? @db.Decimal(12, 4)
  volume1hChangePercent Decimal? @db.Decimal(12, 4)
  volume24hChangePercent Decimal? @db.Decimal(12, 4)
  volumeBuy1mUsd      Decimal? @db.Decimal(18, 2)
  volumeBuy5mUsd      Decimal? @db.Decimal(18, 2)
  volumeBuy30mUsd     Decimal? @db.Decimal(18, 2)
  volumeBuy1hUsd      Decimal? @db.Decimal(18, 2)
  volumeBuy24hUsd     Decimal? @db.Decimal(18, 2)
  volumeSell1mUsd     Decimal? @db.Decimal(18, 2)
  volumeSell5mUsd     Decimal? @db.Decimal(18, 2)
  volumeSell30mUsd    Decimal? @db.Decimal(18, 2)
  volumeSell1hUsd     Decimal? @db.Decimal(18, 2)
  volumeSell24hUsd    Decimal? @db.Decimal(18, 2)
  uniqueWallets1m     Int?
  uniqueWallets5m     Int?
  uniqueWallets30m    Int?
  uniqueWallets1h     Int?
  uniqueWallets24h    Int?
  trades1m            Int?
  trades5m            Int?
  trades30m           Int?
  trades1h            Int?
  trades24h           Int?
  buys1m              Int?
  buys5m              Int?
  buys30m             Int?
  buys1h              Int?
  buys24h             Int?
  sells1m             Int?
  sells5m             Int?
  sells30m            Int?
  sells1h             Int?
  sells24h            Int?
  buySellRatio        Decimal? @db.Decimal(12, 4)
  priceChange1mPercent Decimal? @db.Decimal(12, 4)
  priceChange5mPercent Decimal? @db.Decimal(12, 4)
  priceChange30mPercent Decimal? @db.Decimal(12, 4)
  priceChange1hPercent Decimal? @db.Decimal(12, 4)
  priceChange24hPercent Decimal? @db.Decimal(12, 4)
  graduationAgeSeconds Int?
  top10HolderPercent  Decimal? @db.Decimal(8, 4)
  largestHolderPercent Decimal? @db.Decimal(8, 4)
  largestAccountsCount Int?
  largestHolderAddress String?
  creatorBalancePercent Decimal? @db.Decimal(8, 4)
  ownerBalancePercent Decimal? @db.Decimal(8, 4)
  updateAuthorityBalancePercent Decimal? @db.Decimal(8, 4)
  top10UserPercent   Decimal? @db.Decimal(8, 4)
  mintAuthorityActive Boolean?
  freezeAuthorityActive Boolean?
  transferFeeEnabled Boolean?
  transferFeePercent  Decimal? @db.Decimal(8, 4)
  trueToken          Boolean?
  token2022          Boolean?
  nonTransferable    Boolean?
  fakeToken           Boolean?
  honeypot            Boolean?
  freezeable          Boolean?
  mutableMetadata     Boolean?
  securityRisk        String?
  metadata            Json?
  capturedAt          DateTime @default(now())

  @@index([mint, capturedAt])
  @@index([trigger, capturedAt])
  @@index([capturedAt, liquidityUsd])
  @@index([capturedAt, volume5mUsd])
  @@index([capturedAt, buySellRatio])
  @@index([candidateId])
  @@index([positionId])
}
