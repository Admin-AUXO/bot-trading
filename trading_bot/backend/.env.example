DATABASE_URL="postgresql://botuser:botpass@localhost:5432/trading_bot"
REDIS_URL="redis://localhost:6379"

HELIUS_API_KEY=""
HELIUS_RPC_URL="https://mainnet.helius-rpc.com/?api-key="
HELIUS_WS_URL="wss://mainnet.helius-rpc.com/?api-key="
HELIUS_WEBHOOK_SECRET=""

BIRDEYE_API_KEY=""
# Lite = 1.5M CU/month with 30m S2 catch-up, Starter = 5M CU/month with 10m S2 catch-up
BIRDEYE_PLAN="LITE"
JUPITER_API_KEY=""
JUPITER_BASE_URL="https://api.jup.ag"
JUPITER_PRICE_PATH="/price/v3"
JUPITER_SWAP_PATH="/swap/v1"
S2_ENABLE_NEW_LISTING_FALLBACK="false"

SOLANA_PRIVATE_KEY=""
SOLANA_PUBLIC_KEY=""

JITO_TIP_ACCOUNT=""

BOT_PORT=3001
DASHBOARD_PORT=3000

NODE_ENV="development"
LOG_LEVEL="info"

# LIVE = real trades, DRY_RUN = simulated (real prices, no tx submission)
TRADE_MODE="DRY_RUN"
CONTROL_API_SECRET="replace-with-at-least-16-characters"
