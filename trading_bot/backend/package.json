{
  "name": "solana-trading-bot",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --tsconfig tsconfig.build.json",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:views": "prisma db execute --file prisma/views/create_views.sql",
    "db:setup": "npm run db:push && npm run db:views",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "docker:build": "docker compose --env-file .env.docker -f ../docker-compose.prod.yml build",
    "docker:up": "docker compose --env-file .env.docker -f ../docker-compose.prod.yml up --build -d",
    "docker:down": "docker compose --env-file .env.docker -f ../docker-compose.prod.yml down",
    "docker:logs": "docker compose --env-file .env.docker -f ../docker-compose.prod.yml logs -f"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@jup-ag/api": "^6.0.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@solana/web3.js": "^1.98.4",
    "bullmq": "^5.71.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.3.1",
    "events": "^3.3.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helius-sdk": "^2.2.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.0",
    "lru-cache": "^11.2.7",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.5.0",
    "prisma": "^7.6.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.2"
  }
}
