{
  "name": "trading-bot-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --tsconfig tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lab:discovery": "tsx scripts/discovery-lab.ts",
    "lab:pack-bench": "tsx scripts/discovery-lab-pack-bench.ts",
    "lab:telegram-alert": "tsx scripts/discovery-lab-telegram-alert.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:dangerous": "prisma db push --accept-data-loss",
    "db:views": "prisma db execute --file prisma/views/create_views.sql",
    "db:setup": "npm run db:push && npm run db:views",
    "db:setup:dangerous": "npm run db:push:dangerous && npm run db:views"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.6.0",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "prisma": "^7.6.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.2"
  }
}
