{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "Claude Code project settings for bot-trading — graduation trading bot in trading_bot/",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npx tsc *)",
      "Bash(npx prisma *)",
      "Bash(docker compose *)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git diff --stat)",
      "Bash(git log --oneline -20)",
      "Bash(git branch)",
      "Bash(git show *)",
      "Bash(node ./.codex/scripts/install-mcp-config.cjs *)",
      "Bash(node ./.codex/scripts/graphify.mjs *)",
      "Bash(node ./.codex/scripts/graphify-rebuild.mjs)",
      "Bash(node ./scripts/claude-harness/*)",
      "Bash(bash ./scripts/claude-harness/*)",
      "Read(./**)",
      "Edit(./trading_bot/**)",
      "Edit(./notes/**)",
      "Edit(./.agents/**)",
      "Edit(./.codex/**)",
      "Edit(./.claude/**)",
      "Edit(./scripts/**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(dropdb *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Edit(./trading_bot/backend/prisma/migrations/**)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "browsermcp",
    "desktop_commander",
    "birdeye-mcp",
    "helius",
    "firecrawl",
    "context7",
    "github",
    "grafana",
    "postgres",
    "fetch",
    "time",
    "chrome_devtools",
    "shadcn"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/scripts/session-start-hook.cjs"
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "MAX_THINKING_TOKENS": "10000"
  },
  "includeGitInstructions": true,
  "respectGitignore": true,
  "showClearContextOnPlanAccept": false
}
