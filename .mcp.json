{
  "mcpServers": {
    "desktop_commander": {
      "command": "node",
      "args": [".codex/scripts/start-desktop-commander.cjs"],
      "enabled": true,
      "required": false
    },
    "birdeye-mcp": {
      "command": "node",
      "args": [".codex/scripts/start-birdeye-mcp.cjs"],
      "enabled": true,
      "required": false
    },
    "helius": {
      "command": "node",
      "args": [".codex/scripts/start-stdio-command.cjs", "npx", "-y", "helius-mcp@latest"],
      "enabled": false,
      "required": false
    },
    "firecrawl": {
      "command": "node",
      "args": [".codex/scripts/start-firecrawl-mcp.cjs"],
      "enabled": false,
      "required": false
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "required": false
    },
    "postgres": {
      "command": "node",
      "args": [
        ".codex/scripts/start-stdio-command.cjs",
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://botuser:botpass@127.0.0.1:56432/trading_bot"
      ],
      "enabled": false,
      "required": false
    },
    "fetch": {
      "command": "node",
      "args": [".codex/scripts/start-stdio-command.cjs", "uvx", "mcp-server-fetch"],
      "enabled": false,
      "required": false
    },
    "time": {
      "command": "node",
      "args": [".codex/scripts/start-stdio-command.cjs", "uvx", "mcp-server-time"],
      "enabled": false,
      "required": false
    },
    "chrome_devtools": {
      "command": "node",
      "args": [".codex/scripts/start-stdio-command.cjs", "npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": false,
      "required": false
    },
    "shadcn": {
      "command": "node",
      "args": [".codex/scripts/start-stdio-command.cjs", "npx", "-y", "shadcn@latest", "mcp"],
      "enabled": false,
      "required": false
    }
  }
}
